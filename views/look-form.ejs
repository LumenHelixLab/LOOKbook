<% title = look ? 'Edit Look' : 'New Look' %>
<div class="page-header">
  <h1><%= look ? 'Edit Look' : 'New Look' %></h1>
  <a href="/looks" class="btn btn-secondary">Cancel</a>
</div>

<form action="<%= look ? `/api/looks/${look.id}?_method=PUT` : '/api/looks' %>" method="POST" class="form">
  <div class="field">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" value="<%= look ? look.title : '' %>" required>
  </div>
  <div class="field">
    <label for="description">Description</label>
    <textarea id="description" name="description" rows="4"><%= look ? look.description || '' : '' %></textarea>
  </div>
  <div class="field">
    <label for="image_url">Image URL</label>
    <input type="url" id="image_url" name="image_url" value="<%= look ? look.image_url || '' : '' %>">
  </div>
  <div class="field">
    <label for="tags">Tags</label>
    <input type="text" id="tags" name="tags" value="<%= look ? look.tags || '' : '' %>">
  </div>
  <div class="actions">
    <button type="submit" class="btn btn-primary"><%= look ? 'Update' : 'Create' %></button>
  </div>
</form>
